{
  "name": "Link Invoice To Customer",
  "description": "Automatically copies customer_id from the related job onto new invoices.",
  "trigger": {
    "condition": null,
    "config": {
      "trigger_type": "entity",
      "events": [
        "create"
      ],
      "entity_name": "Invoice"
    }
  },
  "definition": {
    "document": {
      "dsl": "1.0.0",
      "name": "link_invoice_to_customer",
      "version": "1.0",
      "namespace": "base44"
    },
    "do": [
      {
        "run_function": {
          "call": "invoke_backend_function",
          "with": {
            "function_name": "linkJobToCustomer",
            "args": {}
          },
          "then": "end"
        }
      }
    ]
  }
}