    "test:e2e": "node scripts/run-playwright.mjs",
    "test:e2e:debug": "node scripts/run-playwright.mjs --debug",
    "test:watch": "vitest",
    "typecheck": "tsc -p ./jsconfig.json",
    "preview": "vite preview"
  },
  "dependencies": {
